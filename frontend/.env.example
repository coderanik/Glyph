# Clerk Authentication Keys (Get these from your Clerk dashboard at https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk Auth Navigation Routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# API Server URL (Points to the Hono backend server)
NEXT_PUBLIC_API_URL=http://localhost:8083

# Optional: WebSocket origin only (no path). Defaults to ws:// + host from NEXT_PUBLIC_API_URL.
# NEXT_PUBLIC_WS_URL=ws://localhost:8083

# Gemini API Settings (Required for AI assistant features on the backend)
# Get a key from Google AI Studio at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

