# ==============================================================================
# Glyph Unified Environment Configuration Example
# Copy this file to .env at the root of the repository and fill in your keys.
# ==============================================================================

# ── CLERK AUTHENTICATION ──────────────────────────────────────────────────────
# Obtain keys from your Clerk Dashboard (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk Navigation Routes (Default routes configured in the frontend)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── API & SERVICE URLS ────────────────────────────────────────────────────────
# Port and public URL for the backend server
PORT=8083
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8083

# Optional: WebSocket origin only (no path). Defaults to ws:// + host from NEXT_PUBLIC_API_URL.
# NEXT_PUBLIC_WS_URL=ws://localhost:8083

# ── POSTGRESQL DATABASE ───────────────────────────────────────────────────────
# Local PostgreSQL credentials used by the 'db' container
POSTGRES_USER=glyph
POSTGRES_PASSWORD=glyph_password
POSTGRES_DB=glyph

# Database URL used when running the app locally on the host machine (connecting to exposed port 5433).
# Docker Compose will override this internally to connect to the db service container on port 5432.
DATABASE_URL=postgresql://glyph:glyph_password@localhost:5433/glyph
DIRECT_URL=postgresql://glyph:glyph_password@localhost:5433/glyph

# ── GEMINI AI ASSISTANT ───────────────────────────────────────────────────────
# Obtain a key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
